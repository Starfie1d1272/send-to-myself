# 复制为 .env 后修改。docker compose 会自动读取。

# —— 必填 ——
# 登录口令（单用户）。务必设置一个强口令；留空将关闭认证（仅限本地开发）。
AUTH_PASSWORD=change-me-please

# —— 可选 ——
# 经 HTTPS 反代时保持 true；纯 HTTP 本地直连时设 false 否则 cookie 不生效
SECURE_COOKIE=true
# 回收站保留天数
TRASH_RETENTION_DAYS=30
# 单文件上传上限（字节），默认 50MB
MAX_UPLOAD_BYTES=52428800
# 登录会话有效期（天）
SESSION_TTL_DAYS=30
